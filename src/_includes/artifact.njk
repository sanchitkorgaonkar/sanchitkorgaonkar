---
layout: base.njk
---

<article>
  <header class="article-header">
    <div class="article-label">Artifact {% if type %}&nbsp;·&nbsp; {{ type }}{% endif %}</div>
    <h1 class="article-title">{{ title }}</h1>
    <div class="article-meta">
      {{ year if year }}
      {% if link %} &nbsp;·&nbsp; <a href="{{ link }}" target="_blank" rel="noopener" style="color: var(--accent);">View →</a>{% endif %}
    </div>
  </header>

  <div class="article-body">
    {{ content | safe }}
  </div>

  <div class="article-back">
    <a href="/artifacts/">← All artifacts</a>
  </div>
</article>
