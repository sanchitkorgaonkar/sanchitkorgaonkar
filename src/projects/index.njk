---
layout: base.njk
title: Projects
description: Systems and tools built at the intersection of AI and execution intelligence.
---

<div class="page-header">
  <div class="page-title">Projects</div>
  <div class="page-description">Systems and tools built at the intersection of AI and execution intelligence.</div>
</div>

{% if collections.projects.length > 0 %}
<ul class="content-list">
  {% for project in collections.projects %}
  <li class="content-item">
    <a href="{{ project.url }}">
      <div class="item-meta">{{ project.data.year if project.data.year }}{% if project.data.status %} &nbsp;·&nbsp; <span class="tag">{{ project.data.status }}</span>{% endif %}</div>
      <div class="item-title">{{ project.data.title }}</div>
      {% if project.data.excerpt %}<div class="item-excerpt">{{ project.data.excerpt }}</div>{% endif %}
    </a>
  </li>
  {% endfor %}
</ul>
{% else %}
<div class="empty-state">Projects coming soon.</div>
{% endif %}
